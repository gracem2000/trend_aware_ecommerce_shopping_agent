[project]
entrypoint = "index.html"
requires = [ "python-3.12" ]
template = "native-static"
version = "0.0.27"
appliedPatches = [ ]

[dev]
build = [ "sh", "-c", "pip install -q -r requirements.txt" ]
run = [
  "sh",
  "-c",
  "uvicorn main:app --host 0.0.0.0 --port ${DEPLOY_RUN_PORT}"
]

[deploy]
build = [ "sh", "-c", "pip install -q -r requirements.txt" ]
run = [
  "sh",
  "-c",
  "uvicorn main:app --host 0.0.0.0 --port ${DEPLOY_RUN_PORT}"
]
