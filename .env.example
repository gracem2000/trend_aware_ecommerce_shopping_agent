# 复制为 .env 并按需修改（本地开发用）。PaaS 部署时在平台控制台设置同名变量。

# SQLite 数据库文件路径。
# 本地默认 data/app.db；PaaS 部署时指向持久卷，例如 /data/app.db
DATABASE_PATH=data/app.db

# 流水线自动调度间隔（秒）。演示默认 5 分钟。
PIPELINE_INTERVAL_SECONDS=300

# 每个 Agent 面板最多保留多少条最近日志
LOG_RETENTION_PER_AGENT=15

# 首页推荐 / 搜索最多返回条数
RECOMMEND_LIMIT=20

# LLM 提供方：mock（默认，演示用，无需 key）/ deepseek / openai / glm ...
# 接真模型时在 core/llm.py:get_llm() 增加对应分支，并把这里改成对应名称。
LLM_PROVIDER=mock
