# 复制为 .env 并按需修改（本地开发用）。PaaS 部署时在平台控制台设置同名变量。

# ============ 数据库 ============
# SQLite 文件路径。本地默认 data/app.db；PaaS 指向持久卷，如 /data/app.db
DATABASE_PATH=data/app.db

# ============ 流水线调度 ============
# 自动调度间隔（秒）。mock 模式可 300(5分钟)；真实 GLM 模式建议 1800(30分钟) 省额度
PIPELINE_INTERVAL_SECONDS=300
LOG_RETENTION_PER_AGENT=15
RECOMMEND_LIMIT=20

# ============ LLM（感知层吸收自 JD 项目）============
# 提供方：mock（默认，无 key 演示）/ glm（智谱 GLM，需配 ZHIPU_API_KEY）
LLM_PROVIDER=mock
# 智谱 API Key。⚠️ 切勿提交到 git！JD 原项目的 key 已泄露，请去智谱后台轮换。
ZHIPU_API_KEY=
DEFAULT_MODEL=glm-4.6          # JD 原项目用 glm-5.1；按你的账号可用模型调整
TEMPERATURE=0.7
MAX_TOKENS=2000

# ============ 感知层 ============
HOT_FETCH_LIMIT=10             # 每次抓百度热搜前 N 条
SCENE_LIMIT_PER_RUN=3          # 每次流水线最多挖掘几条热点场景（控 LLM 成本）
MIN_CONFIDENCE=0.3             # 商品匹配置信度下限
REQUEST_TIMEOUT=10             # 热搜抓取超时（秒）
SEASONAL_DAYS_BEFORE=3
SEASONAL_DAYS_AFTER=21
